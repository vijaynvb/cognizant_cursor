# Order Management System - Terraform Variables Example
# Copy to terraform.tfvars and fill in sensitive values

project_name = "order-mgmt"
environment  = "dev"
aws_region   = "us-east-1"

vpc_cidr = "10.0.0.0/16"

# Database - REQUIRED: Set these via environment variables or terraform.tfvars
# db_username = "admin"
# db_password = "CHANGE_ME_STRONG_PASSWORD"

# Optional overrides
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_engine_version    = "16.4"

# Set to true for dev if you need external access (e.g., from local machine)
db_publicly_accessible = false
